.page {
  padding: 24rpx;
  padding-bottom: 60rpx;
}

/* ── 状态栏 ── */
.status-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  flex-shrink: 0;
}
.dot-online  { background: #07c160; }
.dot-offline { background: #ccc; }

.status-text {
  flex: 1;
  font-size: 26rpx;
  color: #555;
}

.device-badge {
  font-size: 22rpx;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
}
.badge-online  { background: #e8f7ef; color: #07c160; }
.badge-offline { background: #f5f5f5; color: #999; }

/* ── 报警横幅 ── */
.alarm-banner {
  display: flex;
  align-items: center;
  background: #ff4d4f;
  border-radius: 16rpx;
  padding: 22rpx 28rpx;
  margin-bottom: 20rpx;
}
.alarm-icon {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 16rpx;
  width: 40rpx;
  text-align: center;
}
.alarm-text {
  flex: 1;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}
.alarm-clear-btn {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  background: rgba(255,255,255,0.25);
  color: #fff;
  border-radius: 30rpx;
  border: none;
  line-height: 1.4;
}

/* ── 通用 section ── */
.section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.section-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #666;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}

/* ── 数据卡片网格 ── */
.grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.data-card {
  background: #f8f9fb;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 120rpx;
  transition: background 0.3s;
}
.data-card.card-warn  { background: #fff7e6; }
.data-card.card-alert { background: #fff1f0; }
.data-card.card-info  { background: #e6f4ff; }

.data-icon {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}
.data-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #222;
  line-height: 1.2;
}
.data-unit {
  font-size: 20rpx;
  color: #aaa;
  margin-top: 4rpx;
}
.mode-value {
  font-size: 32rpx;
}

/* ── 模式按钮 ── */
.btn-row {
  display: flex;
  gap: 16rpx;
}

.mode-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
  background: #f0f2f5;
  color: #555;
  border: none;
  padding: 0;
}
.mode-btn.mode-active {
  background: #1976d2;
  color: #fff;
  font-weight: 600;
}

/* ── 控制按钮 ── */
.ctrl-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
  padding: 0;
  color: #fff;
}
.btn-red   { background: #ff4d4f; }
.btn-green { background: #07c160; }
.btn-gray  { background: #d9d9d9; color: #555; }

/* ── 开关行 ── */
.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.switch-row:last-child {
  border-bottom: none;
}
.switch-label {
  font-size: 30rpx;
  color: #333;
}

/* ── 消警按钮 ── */
.full-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  padding: 0;
}
.btn-warn {
  background: #ff7a00;
  color: #fff;
}
